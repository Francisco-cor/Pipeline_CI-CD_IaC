# -----------------------------------------------------------------------------
# terraform.tfvars.example — Example variable values
#
# Copy this file to terraform.tfvars and adjust values for your environment.
# NEVER commit terraform.tfvars to version control if it contains real secrets.
# This example file is safe to commit because it contains no real credentials.
#
# Usage:
#   cp terraform.tfvars.example terraform.tfvars
#   # Edit terraform.tfvars as needed
#   terraform plan -var-file="terraform.tfvars"
# -----------------------------------------------------------------------------

project_name = "erp-pipeline"
environment  = "dev"
aws_region   = "us-east-1"

db_name     = "erpdb"
db_username = "erpadmin"
# db_password is intentionally absent — it is auto-generated by the database
# module using random_password and stored in AWS Secrets Manager.
# Retrieve it after apply with:
#   aws secretsmanager get-secret-value --secret-id /erp/db-url

app_port = 3000

# GitHub repo in owner/name format — used to scope the OIDC trust policy.
# Only this repository's workflows will be able to assume the GitHub Actions IAM role.
github_repo = "your-github-username/Pipeline_CI-CD_IaC"

# Email for CloudWatch alarm notifications (optional — leave empty to skip).
# After terraform apply, confirm the subscription from your inbox.
alert_email = ""
